          "value": "\"analysis_runs\".\"attempt_number\" >= 1"
        },
        "analysis_runs_safe_error_code_nonblank_ck": {
          "name": "analysis_runs_safe_error_code_nonblank_ck",
          "value": "\"analysis_runs\".\"safe_error_code\" IS NULL OR btrim(\"analysis_runs\".\"safe_error_code\") <> ''"
        },
        "analysis_runs_state_ck": {
          "name": "analysis_runs_state_ck",
          "value": "\n        (\n          \"analysis_runs\".\"status\" = 'processing'\n          AND \"analysis_runs\".\"lease_expires_at\" IS NOT NULL\n          AND \"analysis_runs\".\"finished_at\" IS NULL\n          AND \"analysis_runs\".\"safe_error_code\" IS NULL\n        )\n        OR\n        (\n          \"analysis_runs\".\"status\" = 'ready'\n          AND \"analysis_runs\".\"lease_expires_at\" IS NULL\n          AND \"analysis_runs\".\"finished_at\" IS NOT NULL\n          AND \"analysis_runs\".\"safe_error_code\" IS NULL\n        )\n        OR\n        (\n          \"analysis_runs\".\"status\" = 'failed'\n          AND \"analysis_runs\".\"lease_expires_at\" IS NULL\n          AND \"analysis_runs\".\"finished_at\" IS NOT NULL\n          AND \"analysis_runs\".\"safe_error_code\" IS NOT NULL\n          AND btrim(\"analysis_runs\".\"safe_error_code\") <> ''\n        )\n      "
        },
        "analysis_runs_finished_time_ck": {
          "name": "analysis_runs_finished_time_ck",
          "value": "\"analysis_runs\".\"finished_at\" IS NULL OR \"analysis_runs\".\"finished_at\" >= \"analysis_runs\".\"started_at\""
        },
        "analysis_runs_processing_lease_time_ck": {
          "name": "analysis_runs_processing_lease_time_ck",
          "value": "\"analysis_runs\".\"status\" <> 'processing' OR \"analysis_runs\".\"lease_expires_at\" > \"analysis_runs\".\"started_at\""
        },
        "analysis_runs_updated_time_ck": {
          "name": "analysis_runs_updated_time_ck",
          "value": "\"analysis_runs\".\"updated_at\" >= \"analysis_runs\".\"created_at\""
        }
      },
