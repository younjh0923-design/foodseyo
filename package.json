{
  "name": "foodseyo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/migrate-analysis-cache.mts",
    "db:verify-analysis-cache": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/verify-analysis-cache-database.mts",
    "db:verify-analysis-cache-runtime": "node --no-warnings --conditions=react-server --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --env-file-if-exists=.env.local scripts/verify-analysis-cache-repositories.mts",
    "db:verify-analysis-cache-integration": "node --no-warnings --conditions=react-server --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --env-file-if-exists=.env.local scripts/verify-analysis-cache-integration.mts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-all.mts",
    "validate:quick": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-quick.mts",
    "validate:menu": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-menu.mts",
    "validate:results": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-results.mts",
    "validate:consistency": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-analysis-consistency.mts",
    "validate:consistency-integration": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-consistency-integration.mts",
    "validate:cache-contract": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-menu-cache-contract.mts",
    "validate:analysis-cache-schema": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-analysis-cache-schema.mts",
    "validate:structured-menu-schema-draft": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-structured-menu-schema-draft.mts",
    "validate:database-program-charter": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-database-program-charter.mts",
    "validate:analysis-cache-repositories": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-analysis-cache-repositories.mts",
    "validate:analysis-cache-integration": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-analysis-cache-integration.mts",
    "validate:security": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-repository-security.mts",
    "verify:quick": "pnpm lint && pnpm typecheck && pnpm validate:quick",
    "verify:menu": "pnpm validate:menu",
    "verify:results": "pnpm validate:results",
    "verify:consistency": "pnpm validate:consistency",
    "verify:consistency-integration": "pnpm validate:consistency-integration",
    "verify:cache-contract": "pnpm validate:cache-contract",
    "verify:analysis-cache-schema": "pnpm validate:analysis-cache-schema",
    "verify:structured-menu-schema-draft": "pnpm validate:structured-menu-schema-draft",
    "verify:database-program-charter": "pnpm validate:database-program-charter",
    "verify:analysis-cache-repositories": "pnpm validate:analysis-cache-repositories",
    "verify:analysis-cache-integration": "pnpm validate:analysis-cache-integration",
    "verify:full": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm validate:security",
    "smoke:menu-analysis": "node --conditions=react-server --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/smoke-menu-analysis.mts"
  },
  "dependencies": {
    "@vercel/functions": "3.7.5",
    "drizzle-orm": "0.45.2",
    "lucide-react": "latest",
    "next": "latest",
    "openai": "^6.46.0",
    "pg": "8.22.0",
    "react": "latest",
    "react-dom": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/pg": "8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.7.0"
}
